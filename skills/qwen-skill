#!/usr/bin/env python3
"""
Qwen Code Skill - iMessage Reader
让 Qwen Code 可以直接调用 iMessage 读取功能
"""

import sys
import os
import json

# 添加技能路径
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from imessage.imessage_skill import (
    get_last_message,
    search_contact_messages,
    get_all_contacts,
    export_messages,
    format_timestamp
)


def print_help():
    """打印帮助信息"""
    help_text = """
╔═══════════════════════════════════════════════════════════╗
║                    iMessage Skill                         ║
║              读取 macOS iMessage 消息数据                   ║
╠═══════════════════════════════════════════════════════════╣
║  用法：                                                   ║
║    qwen-skill imessage <command> [arguments]              ║
║                                                           ║
║  命令：                                                   ║
║    last <contact>           获取最后一条消息               ║
║    search <contact> [limit] 搜索消息（默认 20 条）          ║
║    contacts                 查看所有联系人                 ║
║    export <contact> [file]  导出消息为 JSON                ║
║                                                           ║
║  示例：                                                   ║
║    qwen-skill imessage last "+18336801616"                ║
║    qwen-skill imessage search "james" 10                  ║
║    qwen-skill imessage contacts                           ║
║    qwen-skill imessage export "+18336801616" msg.json     ║
╚═══════════════════════════════════════════════════════════╝
"""
    print(help_text)


def format_message(msg: dict) -> str:
    """格式化消息输出"""
    if not msg:
        return "❌ 未找到消息"
    
    direction = "📤 我" if msg.get("is_from_me") else "📥 对方"
    return f"""
╭─────────────────────────────────────────────
│ {direction} | {msg.get('handle', '未知')}
├─────────────────────────────────────────────
│ 📅 时间：{msg.get('date', '未知')}
│ 💬 内容：{msg.get('text', '[无内容]')}
╰─────────────────────────────────────────────
"""


def format_messages(messages: list) -> str:
    """格式化多条消息输出"""
    if not messages:
        return "❌ 未找到消息"
    
    output = f"✅ 找到 {len(messages)} 条消息:\n\n"
    for i, msg in enumerate(messages, 1):
        direction = "📤" if msg.get("is_from_me") else "📥"
        output += f"[{i}] {direction} {msg.get('date', '未知')}: {msg.get('text', '[无内容]')}\n"
    
    return output


def main():
    """主函数"""
    if len(sys.argv) < 2:
        print_help()
        sys.exit(0)
    
    skill_name = sys.argv[1]
    
    if skill_name != "imessage":
        print(f"❌ 未知技能：{skill_name}")
        print_help()
        sys.exit(1)
    
    if len(sys.argv) < 3:
        print_help()
        sys.exit(1)
    
    command = sys.argv[2]
    
    try:
        if command == "last":
            if len(sys.argv) < 4:
                print("❌ 请提供联系人姓名/电话")
                print("用法：qwen-skill imessage last <contact>")
                sys.exit(1)
            
            contact = sys.argv[3]
            msg = get_last_message(contact)
            print(format_message(msg))
        
        elif command == "search":
            if len(sys.argv) < 4:
                print("❌ 请提供联系人姓名/电话")
                print("用法：qwen-skill imessage search <contact> [limit]")
                sys.exit(1)
            
            contact = sys.argv[3]
            limit = int(sys.argv[4]) if len(sys.argv) > 4 else 20
            messages = search_contact_messages(contact, limit)
            print(format_messages(messages))
        
        elif command == "contacts":
            contacts = get_all_contacts()
            print(f"✅ 共找到 {len(contacts)} 个联系人:\n")
            for contact in contacts[:50]:  # 限制显示 50 个
                name = contact.get('display_name') or contact.get('handle')
                print(f"  • {name}")
            if len(contacts) > 50:
                print(f"  ... 还有 {len(contacts) - 50} 个联系人")
        
        elif command == "export":
            if len(sys.argv) < 4:
                print("❌ 请提供联系人姓名/电话")
                print("用法：qwen-skill imessage export <contact> [output_file]")
                sys.exit(1)
            
            contact = sys.argv[3]
            output_file = sys.argv[4] if len(sys.argv) > 4 else "messages.json"
            file_path = export_messages(contact, output_file)
            print(f"✅ 消息已导出到：{file_path}")
        
        else:
            print(f"❌ 未知命令：{command}")
            print_help()
            sys.exit(1)
    
    except FileNotFoundError as e:
        print(f"❌ 错误：{e}")
        print("\n💡 提示：请确保在 macOS 系统上运行")
        sys.exit(1)
    except PermissionError:
        print("❌ 权限错误：无法访问 iMessage 数据库")
        print("\n💡 解决方法：")
        print("   1. 打开 系统设置 > 隐私与安全性 > 完全磁盘访问权限")
        print("   2. 添加您的终端应用")
        print("   3. 重启终端后重试")
        sys.exit(1)
    except Exception as e:
        print(f"❌ 发生错误：{e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
