{
  "skills": [
    {
      "name": "imessage",
      "description": "读取 macOS iMessage 消息数据",
      "version": "1.0.0",
      "author": "iMessage Skill Team",
      "entry": "imessage_skill.py",
      "commands": [
        {
          "name": "last",
          "description": "获取指定联系人的最后一条消息",
          "usage": "imessage last <contact>",
          "example": "imessage last +18336801616",
          "parameters": [
            {
              "name": "contact",
              "type": "string",
              "required": true,
              "description": "联系人姓名、电话号码或邮箱"
            }
          ]
        },
        {
          "name": "search",
          "description": "搜索指定联系人的消息",
          "usage": "imessage search <contact> [limit]",
          "example": "imessage search +18336801616 10",
          "parameters": [
            {
              "name": "contact",
              "type": "string",
              "required": true,
              "description": "联系人姓名、电话号码或邮箱"
            },
            {
              "name": "limit",
              "type": "number",
              "required": false,
              "default": 20,
              "description": "返回消息数量限制"
            }
          ]
        },
        {
          "name": "contacts",
          "description": "查看所有联系人列表",
          "usage": "imessage contacts",
          "example": "imessage contacts",
          "parameters": []
        },
        {
          "name": "export",
          "description": "导出联系人消息为 JSON 文件",
          "usage": "imessage export <contact> [output_file]",
          "example": "imessage export +18336801616 messages.json",
          "parameters": [
            {
              "name": "contact",
              "type": "string",
              "required": true,
              "description": "联系人姓名、电话号码或邮箱"
            },
            {
              "name": "output_file",
              "type": "string",
              "required": false,
              "default": "messages.json",
              "description": "输出文件路径"
            }
          ]
        }
      ],
      "requirements": [
        "macOS 操作系统",
        "Python 3.8+",
        "终端完全磁盘访问权限"
      ],
      "permissions": {
        "disk_access": true,
        "database_path": "~/Library/Messages/chat.db"
      },
      "config": {
        "timeout": 30000,
        "retry": 3
      }
    }
  ]
}
