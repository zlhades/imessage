#!/bin/bash
# 🚀 iMessage to Qwen - 自动读取并执行消息指令

CONTACT="${1:-zlhades@icloud.com}"

echo "╔═══════════════════════════════════════════════════════════╗"
echo "║           iMessage → Qwen 自动执行系统                     ║"
echo "╚═══════════════════════════════════════════════════════════╝"
echo ""

# 步骤 1: 读取最后一条消息
echo "📱 正在读取 $CONTACT 的最后一条消息..."
echo ""

MESSAGE=$(python3 /Users/benson/Documents/incident/skills/imessage/imessage_skill_v2.py last "$CONTACT")

if [ $? -ne 0 ]; then
    echo "❌ 读取消息失败"
    exit 1
fi

# 提取消息内容
TEXT=$(echo "$MESSAGE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('text',''))")
DATE=$(echo "$MESSAGE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('date',''))")
FROM=$(echo "$MESSAGE" | python3 -c "import sys,json; d=json.load(sys.stdin); print('对方' if not d.get('is_from_me') else '我')")

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📅 $DATE | 👤 $FROM"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "💬 $TEXT"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# 步骤 2: 让 Qwen 分析并执行
echo "🤖 正在让 Qwen 分析并执行..."
echo ""

# 创建临时指令文件
TMPFILE="/tmp/imessage_instruction_$$_.txt"
cat > "$TMPFILE" << EOF
【iMessage 指令】
时间：$DATE
发送者：$FROM

指令内容：
$TEXT

---
请分析以上 iMessage 消息中的指令并执行。
如果是可执行的任务，请：
1. 识别任务类型
2. 执行相应操作
3. 返回执行结果
EOF

# 检查是否有 qwen-code CLI
if command -v qwen &> /dev/null; then
    qwen "请执行以下 iMessage 指令：

$TEXT"
else
    echo "⚠️  未找到 qwen-code CLI"
    echo ""
    echo "📋 指令内容已保存到：$TMPFILE"
    echo ""
    echo "请手动将上述内容发送给 Qwen Code"
fi

# 清理临时文件
rm -f "$TMPFILE"
