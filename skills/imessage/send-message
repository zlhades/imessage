#!/bin/bash
# 发送 iMessage 回复

CONTACT="$1"
MESSAGE="$2"

if [ -z "$CONTACT" ] || [ -z "$MESSAGE" ]; then
    echo "用法：$0 <联系人> <消息内容>"
    echo "示例：$0 zlhades@hotmail.com 'Hello'"
    exit 1
fi

# 使用 AppleScript 发送 iMessage
osascript << EOF
tell application "Messages"
    set targetBuddy to "$CONTACT"
    send "$MESSAGE" to buddy targetBuddy of (service 1 whose service type is iMessage)
end tell
EOF

if [ $? -eq 0 ]; then
    echo "✅ 消息已发送"
    echo "📱 收件人：$CONTACT"
    echo "💬 内容：$MESSAGE"
else
    echo "❌ 发送失败"
    exit 1
fi
