{
  "name": "slack-incident-bot",
  "version": "1.0.0",
  "description": "Slack AI Incident Response Bot with MCP architecture",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "incident": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "mcp:start": "concurrently \"npm run mcp:start:slack\" \"npm run mcp:start:github\" \"npm run mcp:start:prometheus\"",
    "mcp:start:slack": "tsx mcp-servers/slack/src/index.ts",
    "mcp:start:github": "tsx mcp-servers/github/src/index.ts",
    "mcp:start:prometheus": "tsx mcp-servers/prometheus/src/index.ts",
    "mcp:build": "npm run mcp:build:slack && npm run mcp:build:github && npm run mcp:build:prometheus",
    "mcp:build:slack": "cd mcp-servers/slack && npm run build",
    "mcp:build:github": "cd mcp-servers/github && npm run build",
    "mcp:build:prometheus": "cd mcp-servers/prometheus && npm run build"
  },
  "keywords": [
    "slack",
    "incident",
    "mcp",
    "ai",
    "qwen"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@slack/web-api": "^7.0.0",
    "winston": "^3.11.0",
    "yaml": "^2.3.4",
    "dotenv": "^16.3.1",
    "openai": "^4.20.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "tsx": "^4.6.0",
    "concurrently": "^8.2.2",
    "vitest": "^2.0.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^2.0.0",
    "@slack/types": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
